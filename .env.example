# CopyBrief runs for free with these defaults. No secrets are required.
APP_ENV=development
LOG_LEVEL=INFO

# Free/default provider. Keep rule_based for Hugging Face Spaces and local demos.
PROVIDER=rule_based

# OPTIONAL PAID FEATURE: only needed for a future Claude-backed provider.
# Leave blank for the default free MVP. Do not set this in Spaces unless enabling Claude.
ANTHROPIC_API_KEY=
ENABLE_CLAUDE=false

# OPTIONAL PAID/PREMIUM-READY FEATURES: all disabled by default.
ENABLE_PERSISTENCE=false
ENABLE_ANALYTICS=false
ENABLE_AUTH=false
ENABLE_PDF_EXPORT=false

# OPTIONAL LOCAL-ONLY PERSISTENCE: keep disabled for the free demo.
STORAGE_BACKEND=disabled
LOCAL_STORAGE_PATH=.copybrief_data
