APP_ENV=development
LOG_LEVEL=INFO

# Provider registry: rule_based is free/default. anthropic is optional and safe.
PROVIDER=rule_based
ANTHROPIC_API_KEY=

# Premium-ready feature flags. Defaults keep the MVP free and local.
ENABLE_CLAUDE=false
ENABLE_PERSISTENCE=false
ENABLE_ANALYTICS=false
ENABLE_AUTH=false
ENABLE_PDF_EXPORT=false

# Optional only when ENABLE_PERSISTENCE=true and local JSON storage is desired.
STORAGE_BACKEND=disabled
LOCAL_STORAGE_PATH=.copybrief_data
